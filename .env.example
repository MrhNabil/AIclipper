# =============================================================================
# AIClipper Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values for your setup.
# All paths can be relative (to project root) or absolute.

# --- Application ---
APP_NAME=AIClipper
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
SECRET_KEY=change-this-to-a-random-secret-key

# --- Paths ---
UPLOAD_DIR=./uploads
OUTPUT_DIR=./outputs
SUBTITLE_DIR=./subtitles
THUMBNAIL_DIR=./thumbnails
LOG_DIR=./logs
MODEL_DIR=./models

# --- Database ---
DATABASE_URL=sqlite+aiosqlite:///./data/aiclipper.db

# --- Whisper.cpp ---
WHISPER_MODEL=small.en
WHISPER_MODEL_PATH=./models/ggml-small.en.bin
WHISPER_THREADS=4
WHISPER_LANGUAGE=auto

# --- Ollama (default LLM) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2
OLLAMA_TIMEOUT=120

# --- LLM Provider (auto-detected if not set) ---
# Options: ollama, openai, gemini, deepseek
# LLM_PROVIDER=ollama

# --- OpenAI (optional) ---
# OPENAI_API_KEY=sk-...

# --- Google Gemini (optional) ---
# GOOGLE_API_KEY=AIza...

# --- DeepSeek (optional) ---
# DEEPSEEK_API_KEY=sk-...

# --- MediaPipe ---
MEDIAPIPE_MODEL_PATH=./models/blaze_face_short_range.tflite
FACE_SAMPLE_EVERY_N_FRAMES=3

# --- FFmpeg ---
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
OUTPUT_RESOLUTION=1080x1920
OUTPUT_FPS=30
OUTPUT_CRF=21
OUTPUT_PRESET=medium

# --- Clip Settings ---
CLIP_DURATIONS=15,30,60
MAX_CLIPS_PER_VIDEO=10
MIN_CLIP_GAP_SECONDS=10

# --- Scoring Weights ---
WEIGHT_EMOTION=0.25
WEIGHT_DIALOGUE=0.20
WEIGHT_SCENE_CHANGE=0.20
WEIGHT_AUDIO=0.20
WEIGHT_FACE=0.15

# --- Subtitle Defaults ---
SUBTITLE_FONT=Arial
SUBTITLE_FONT_SIZE=24
SUBTITLE_FONT_COLOR=#FFFFFF
SUBTITLE_OUTLINE_COLOR=#000000
SUBTITLE_OUTLINE_WIDTH=2
SUBTITLE_POSITION=bottom
SUBTITLE_HIGHLIGHT_COLOR=#FFD700

# --- YouTube OAuth (optional) ---
YOUTUBE_CLIENT_SECRETS_FILE=./configs/client_secret_youtube.json
YOUTUBE_TOKEN_FILE=./data/youtube_token.json

# --- Facebook OAuth (optional) ---
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_PAGE_ID=
FACEBOOK_ACCESS_TOKEN=
